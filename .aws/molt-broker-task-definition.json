{
  "family": "molt-broker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::901889466248:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::901889466248:role/ecsTaskRoleMoltBroker",
  "volumes": [
    {
      "name": "molt-data",
      "efsVolumeConfiguration": {
        "fileSystemId": "PLACEHOLDER_EFS_ID",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "PLACEHOLDER_EFS_AP_ID",
          "iam": "ENABLED"
        }
      }
    }
  ],
  "containerDefinitions": [
    {
      "name": "molt-broker",
      "image": "PLACEHOLDER_IMAGE",
      "portMappings": [
        {
          "containerPort": 7077,
          "protocol": "tcp"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "molt-data",
          "containerPath": "/app/data",
          "readOnly": false
        }
      ],
      "environment": [
        { "name": "MOLT_HOST",        "value": "0.0.0.0" },
        { "name": "MOLT_PORT",        "value": "7077" },
        { "name": "MOLT_PATH_PREFIX", "value": "/grid" },
        { "name": "MOLT_DATA_DIR",    "value": "/app/data" },
        { "name": "MOLT_AUTH",        "value": "1" },
        { "name": "MOLT_FUEL_REAL",   "value": "0" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/molt-broker",
          "awslogs-region":        "ca-west-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command":     ["CMD-SHELL", "wget -qO- http://127.0.0.1:7077/health || exit 1"],
        "interval":    30,
        "timeout":     5,
        "retries":     3,
        "startPeriod": 30
      }
    }
  ]
}
