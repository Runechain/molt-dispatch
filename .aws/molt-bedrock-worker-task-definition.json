{
  "family": "molt-bedrock-worker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::901889466248:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::901889466248:role/ecsTaskRoleMoltBedrockWorker",
  "containerDefinitions": [
    {
      "name": "molt-bedrock-worker",
      "image": "",
      "command": ["node", "bin/molt.mjs", "worker", "start", "--adapters", "bedrock", "--trust", "4"],
      "environment": [
        { "name": "MOLT_BROKER_URL",      "value": "https://play.runechaingame.com/grid" },
        { "name": "MOLT_BEDROCK_REGION",  "value": "us-east-1" },
        { "name": "MOLT_BEDROCK_MODEL",   "value": "anthropic.claude-3-haiku-20240307-v1:0" }
      ],
      "secrets": [
        {
          "name":      "MOLT_API_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:901889466248:parameter/molt/MOLT_API_KEY"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/molt-bedrock-worker",
          "awslogs-region":        "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command":     ["CMD-SHELL", "node -e \"process.exit(0)\""],
        "interval":    60,
        "timeout":     5,
        "retries":     3,
        "startPeriod": 30
      }
    }
  ]
}
