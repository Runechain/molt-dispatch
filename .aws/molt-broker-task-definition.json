{
  "family": "molt-broker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::901889466248:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::901889466248:role/ecsTaskRoleMoltBroker",
  "volumes": [
    {
      "name": "molt-data",
      "efsVolumeConfiguration": {
        "fileSystemId": "",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "",
          "iam": "ENABLED"
        }
      }
    }
  ],
  "containerDefinitions": [
    {
      "name": "molt-broker",
      "image": "",
      "portMappings": [
        {
          "containerPort": 7077,
          "protocol": "tcp"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "molt-data",
          "containerPath": "/app/data",
          "readOnly": false
        }
      ],
      "environment": [
        { "name": "MOLT_HOST",        "value": "0.0.0.0" },
        { "name": "MOLT_PORT",        "value": "7077" },
        { "name": "MOLT_PATH_PREFIX", "value": "/grid" },
        { "name": "MOLT_DATA_DIR",    "value": "/app/data" },
        { "name": "MOLT_AUTH",        "value": "1" },
        { "name": "MOLT_FUEL_REAL",   "value": "0" },
        { "name": "MOLT_INTEGRATION_AGENT",  "value": "1" },
        { "name": "MOLT_PLANNER_AGENT",      "value": "1" },
        { "name": "MOLT_DELIB_CHEAP",        "value": "deepseek" },
        { "name": "MOLT_DELIB_PREMIUM",      "value": "deepseek" },
        { "name": "MOLT_DELIB_CHEAP_MODEL",  "value": "deepseek-chat" },
        { "name": "MOLT_DELIB_PREMIUM_MODEL","value": "deepseek-reasoner" },
        { "name": "MOLT_OPEN_GRID",        "value": "1" },
        { "name": "MOLT_REQUIRE_IDENTITY", "value": "1" },
        { "name": "MOLT_GAME_URL",         "value": "https://play.runechaingame.com" }
      ],
      "secrets": [
        { "name": "DEEPSEEK_API_KEY", "valueFrom": "arn:aws:ssm:ca-west-1:901889466248:parameter/molt/DEEPSEEK_API_KEY" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/molt-broker",
          "awslogs-region":        "ca-west-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command":     ["CMD-SHELL", "wget -qO- http://127.0.0.1:7077/health || exit 1"],
        "interval":    30,
        "timeout":     5,
        "retries":     3,
        "startPeriod": 30
      }
    }
  ]
}
