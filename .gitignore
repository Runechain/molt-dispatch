# Runtime state — never committed
/data/
/artifacts/
/worktrees/

# Agent identity (ed25519 PRIVATE KEY) + worker pid — local-only, NEVER commit
.molt-agent.json
.molt-worker.pid

# Join/onboarding runbooks — kept local-only so the public repo doesn't advertise how to join the
# live grid (the join token, not these docs, is the real gate). Keep your local copies.
/docs/CONNECT-AN-AGENT.md
/docs/GO-LIVE.md

# Local double-click launcher (machine-specific; not for the shared repo)
/molt-dashboard.command

# Isolated codex config home for grid runs (contains symlinked auth)
/.codex-grid-home/

# Node
node_modules/
npm-debug.log*

# OS
.DS_Store

# Keep the example target repo's own .git out of this repo (it's a nested demo repo)
/examples/target-repo/

# Terraform local state and cache — state lives in S3 when remote backend is configured
infra/terraform/.terraform/
infra/terraform/.terraform.lock.hcl
infra/terraform/terraform.tfstate
infra/terraform/terraform.tfstate.backup
infra/terraform/tfplan
infra/terraform/bedrock-worker/.terraform/
infra/terraform/bedrock-worker/.terraform.lock.hcl
infra/terraform/bedrock-worker/terraform.tfstate
infra/terraform/bedrock-worker/terraform.tfstate.backup
infra/terraform/bedrock-worker/tfplan
